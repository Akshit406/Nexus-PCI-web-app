DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="replace-with-a-long-random-production-secret"
FRONTEND_ORIGIN="http://localhost:5173"
# Public app URL used in outgoing emails (welcome, password reset). If unset
# the value of FRONTEND_ORIGIN is used as a fallback.
PUBLIC_APP_URL="http://localhost:5173"
PORT=4000

# Email / SMTP. When any of SMTP_HOST / SMTP_USER / SMTP_PASS is missing the
# system falls back to logging emails to stdout in dev mode.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="PCI Nexus <no-reply@pcinexus.local>"

# Reminder scheduler (expiration / abandoned / refresh notifications)
REMINDER_SCHEDULER_ENABLED=false
REMINDER_SCHEDULER_INTERVAL_MINUTES=1440
REMINDER_SCHEDULER_RUN_ON_START=false

# Retention / purge job
RETENTION_JOB_ENABLED=false
RETENTION_JOB_INTERVAL_MINUTES=1440
# Number of years past validUntil before an inactive certification is archived.
RETENTION_KEEP_FINALIZED_YEARS=2
# Number of days an archived evidence record is retained before purge.
RETENTION_PURGE_ARCHIVED_AFTER_DAYS=365

# Maintenance mode
MAINTENANCE_MODE_ENABLED=false
MAINTENANCE_MESSAGE="La plataforma esta en mantenimiento operativo. El acceso de administracion permanece disponible."

# Uploads directory (relative to backend working directory or absolute path)
UPLOADS_DIR="./storage"
